// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Continent {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?  // Novo campo
  countries   Country[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("continents")
}

model Country {
  id               String    @id @default(uuid())
  name             String    @unique
  exactName        String?   // Nome oficial verificado para APIs externas
  population       Int?
  officialLanguage String?
  currency         String?
  continentId      String
  continent        Continent @relation(fields: [continentId], references: [id], onDelete: Cascade)
  state            State[]
  cities           City[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("countries")
}

model State {
  id          String @id @default(uuid())
  name        String
  countryId   String
  country     Country @relation(fields: [countryId], references: [id], onDelete: Cascade)
  cities      City[]

  @@unique([name, countryId])
}

model City {
  id          String   @id @default(uuid())
  name        String
  population  Int?     // Novo campo
  latitude    Float?   // Novo campo
  longitude   Float?   // Novo campo
  stateId     String?
  state       State?   @relation(fields: [stateId], references: [id], onDelete: Cascade)
  countryId   String
  country     Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([name, stateId])
  @@map("cities")
}

model User {
  id        String   @id @default(uuid())
  name      String?
  email     String   @unique
  password  String   // Hash da senha para login
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}