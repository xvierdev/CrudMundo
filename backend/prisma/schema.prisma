// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Continent {
  id        String   @id @default(uuid())
  name      String   @unique
  countries Country[] // Relacionamento 1-para-Muitos: Um continente tem vários países
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("continents") // Opcional: Define o nome da tabela no plural no Postgres
}

model Country {
  id          String    @id @default(uuid())
  name        String    @unique
  continentId String
  continent   Continent @relation(fields: [continentId], references: [id], onDelete: Cascade)
  state       State[]   // adicionado conceito de estado
  cities      City[]    // Relacionamento 1-para-Muitos: Um país tem várias cidades
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("countries")
}

model State {
  id          String @id @default(uuid())
  name        String
  countryId   String
  country     Country @relation(fields: [countryId], references: [id])
  cities      City[]

  @@unique([name, countryId])
}

model City {
  id        String   @id @default(uuid())
  name      String
  stateId   String?
  state     State?   @relation(fields: [stateId], references: [id])
  countryId String
  country   Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, stateId])
  @@map("cities")
}

model User {
  id        String   @id @default(uuid())
  name      String?
  email     String   @unique
  password  String   // Hash da senha para login
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}